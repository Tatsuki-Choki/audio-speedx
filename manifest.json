{
  "manifest_version": 3,
  "name": "Custom Speed Controller",
  "version": "1.1",
  "description": "あらゆる音声・動画の再生速度を自由に変更します",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
